{
  "name": "@codex-remote/relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prebuild": "npm run build --workspace @codex-remote/shared",
    "pretest": "npm run build --workspace @codex-remote/shared",
    "pretypecheck": "npm run build --workspace @codex-remote/shared",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codex-remote/shared": "0.1.0",
    "ws": "^8.18.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "vitest": "^3.2.4"
  }
}
